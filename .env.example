# Required Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# OpenAI API Configuration
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_MODEL=gpt-4o

# Notes:
# - OPENAI_API_BASE_URL: Can be changed for Azure OpenAI or other compatible APIs
# - OPENAI_API_KEY: Keep this secret, never commit to git
# - OPENAI_API_MODEL: Use any OpenAI-compatible model (gpt-4o, gpt-3.5-turbo, etc.)
